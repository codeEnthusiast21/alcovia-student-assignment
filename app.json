{
  "expo": {
    "name": "Alcovia Student",
    "slug": "alcovia-student",
    "version": "1.0.0",
    "scheme": "alcovia",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "android": {
      "package": "com.aviral0980.alcoviastudent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6FA"
    }
  }
}